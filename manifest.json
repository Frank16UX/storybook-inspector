{
  "manifest_version": 3,
  "name": "Storybook Inspector",
  "version": "1.0.0",
  "description": "Inspect CSS properties and compare against SCSS design tokens",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_title": "Open Storybook Inspector",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["shared/constants.js", "content/inspector.js"],
      "css": ["content/inspector.css"],
      "all_frames": true,
      "match_origin_as_fallback": true,
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
